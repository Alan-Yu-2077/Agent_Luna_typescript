ANTHROPIC_API_KEY=sk-your-key-here
ANTHROPIC_BASE_URL=https://api.anthropic.com
LUNA_MODEL=claude-opus-4-8
LUNA_MAX_TOKENS=8192
# LUNA_PORT=8787
# LUNA_DEV_TOOLS=1
# LUNA_TRACE=1
# LUNA_VIEWER=1
# LUNA_DB_PATH=./luna.sqlite
# LUNA_INTEGRATION_TESTS=1
LUNA_EMBEDDING_MODEL=text-embedding-3-large
LUNA_EMBEDDING_API_KEY=sk-your-embedding-key
LUNA_EMBEDDING_BASE_URL=https://api.openai.com
# LUNA_SUMMARIZER_API_KEY=sk-separate-key-for-dream-work
# --- v0.6+ persona & message tool ---
# LUNA_PERSONA=1                # 0 disables persona/embodiment/humanity/scene blocks
# LUNA_PERSONA_PATH=            # absolute path overriding packages/server/persona/default.md
# LUNA_MESSAGE_TOOL=1           # default ON since v0.7.0; 0 = legacy reply.token text path
# --- v0.8+ action integrity ---
# LUNA_DECISION_AUDIT=1         # default ON since v0.9.0; 0 stops recording intent-without-act `decision` traces
# LUNA_L1_CONTRACT=1            # default ON since v0.9.0; 0 drops the L1 thinking contract from the system core
# LUNA_INTEGRITY_GUARD=1        # default ON since v0.9.0; 0 disables is_final-promise + intent-without-act retries
# --- v0.10+ proactive agency ---
# LUNA_PROACTIVE=0              # 1 enables proactive turns (manual proactive.fire in v0.10.0; kill switch, default off)
# LUNA_PROACTIVE_MAX_ACTIONS=6  # per-cycle tool-call budget for a proactive turn (runaway-loop backstop)
# LUNA_PROACTIVE_TICK_SECONDS=60      # heartbeat interval (the loop checks whether to wake this often)
# LUNA_PROACTIVE_IDLE_THRESHOLD_MS=600000   # min user-silence before considering a proactive turn (10 min)
# LUNA_PROACTIVE_MIN_INTERVAL_MS=300000     # cooldown between proactive turns (5 min)
# LUNA_PROACTIVE_DAILY_QUOTA=5              # max proactive turns per day
# LUNA_PROACTIVE_QUIET_HOURS=0,1,2,3,4,5    # local hours Luna stays quiet
# LUNA_PROACTIVE_LONG_ABSENCE_MS=64800000   # >this user-gap → she doesn't wake (18h)
# --- v0.18+ web tools (Initiative 11) ---
# LUNA_WEB_SEARCH=0                  # master gate, default OFF; 1 mounts the web_search tool
# LUNA_WEB_SEARCH_API_KEY=           # search provider API key (Tavily by default)
# LUNA_WEB_SEARCH_PROVIDER=tavily    # search provider (tavily)
# LUNA_WEB_SEARCH_TIMEOUT_MS=15000   # per-search timeout (armed onto the tool's abort signal)
# LUNA_WEB_SEARCH_RESULT_CHARS=800   # per-result snippet clip
