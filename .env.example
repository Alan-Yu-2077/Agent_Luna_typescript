ANTHROPIC_API_KEY=sk-your-key-here
ANTHROPIC_BASE_URL=https://api.anthropic.com
LUNA_MODEL=claude-opus-4-8
LUNA_MAX_TOKENS=8192
# --- provider selection (Initiative 16) ---
# LUNA_PROVIDER=anthropic        # 'anthropic' (default) or 'openai' (OpenAI Chat-Completions protocol)
# LUNA_OPENAI_BASE_URL=https://yunwu.ai/v1   # OpenAI-compatible base (falls back to ANTHROPIC_BASE_URL); the provider appends /chat/completions
# LUNA_OPENAI_API_KEY=sk-...     # key for the OpenAI route (falls back to ANTHROPIC_API_KEY — the yunwu gateway uses one key)
#   With LUNA_PROVIDER=openai, set LUNA_MODEL to an OpenAI-protocol model id (e.g. gpt-4o, or an OSS model your gateway serves).
# LUNA_OPENAI_STREAM=1           # real SSE token streaming + interleaved tool-use (default off; the non-streaming path is the fallback)
# LUNA_OPENAI_REASONING=1        # the model is a reasoning model — surface its reasoning as thinking (default off)
# LUNA_PORT=8787
# LUNA_DEV_TOOLS=1
# LUNA_TRACE=1
# LUNA_VIEWER=1
# LUNA_DB_PATH=./luna.sqlite
# LUNA_INTEGRATION_TESTS=1
LUNA_EMBEDDING_MODEL=text-embedding-3-large
LUNA_EMBEDDING_API_KEY=sk-your-embedding-key
LUNA_EMBEDDING_BASE_URL=https://api.openai.com
# LUNA_SUMMARIZER_API_KEY=sk-separate-key-for-dream-work
# --- v0.6+ persona & message tool ---
# LUNA_PERSONA=1                # 0 disables persona/embodiment/humanity/scene blocks
# LUNA_PERSONA_PATH=            # absolute path overriding packages/server/persona/default.md
# LUNA_MESSAGE_TOOL=1           # default ON since v0.7.0; 0 = legacy reply.token text path
# --- v0.8+ action integrity ---
# LUNA_DECISION_AUDIT=1         # default ON since v0.9.0; 0 stops recording intent-without-act `decision` traces
# LUNA_L1_CONTRACT=1            # default ON since v0.9.0; 0 drops the L1 thinking contract from the system core
# LUNA_INTEGRITY_GUARD=1        # default ON since v0.9.0; 0 disables is_final-promise + intent-without-act retries
# --- v0.10+ proactive agency (rail) ---
# LUNA_PROACTIVE=0              # kill switch (default ON since v0.11.0; set 0 to disable all proactive turns)
# LUNA_PROACTIVE_MAX_ACTIONS=6  # per-cycle tool-call budget for a proactive turn (runaway-loop backstop)
# LUNA_PROACTIVE_TICK_SECONDS=60      # heartbeat interval (the detector funnel runs this often)
# LUNA_PROACTIVE_IDLE_FLOOR_MS=60000        # min user-silence before a proactive turn (don't reach in mid-exchange)
# LUNA_PROACTIVE_MIN_INTERVAL_MS=300000     # cooldown between proactive turns (5 min)
# LUNA_PROACTIVE_DAILY_QUOTA=5              # max SPOKEN proactive turns per day (silent drafts don't count)
# LUNA_PROACTIVE_QUIET_HOURS=0,1,2,3,4,5    # local hours Luna stays quiet
# LUNA_PROACTIVE_DEBOUNCE_MS=14400000       # per-trigger-key debounce (don't re-fire the same reason; 4h)
# --- Initiative 15 — deterministic proactive detectors (drafting-as-decision) ---
# LUNA_PROACTIVE_SLOTS=11,20                 # local hours for a guaranteed daily opening (unset = no scheduled floor)
# LUNA_PROACTIVE_WEATHER_SHIFT=0             # 0 disables the weather-shift detector (default on when weather is configured)
# LUNA_PROACTIVE_EVENT_HOOKS=1               # fire at the natural instant (ws reconnect / weather refresh), not just the tick (default off)
# LUNA_PROACTIVE_OPEN_THREADS=1              # enable the openThreadAged detector (default off; heuristic)
# LUNA_PROACTIVE_THREAD_AGE_MS=86400000      # an L3 active_thread older than this is a candidate (24h)
# LUNA_PROACTIVE_FOLLOW_THROUGH=1            # enable the promisedFollowThrough detector (default off; heuristic)
# LUNA_PROACTIVE_PROMISE_AGE_MS=21600000     # an unfollowed promise older than this fires (6h)
# LUNA_PROACTIVE_PROMISE_MAX_AGE_MS=129600000 # ...but past this it's treated as abandoned, won't re-fire (36h)
# --- v0.18+ web tools (Initiative 11) ---
# LUNA_WEB_SEARCH=1                  # default ON since v0.18.2 BUT needs a key; 0 = off. No key ⇒ tool not mounted (graceful degrade)
# LUNA_WEB_SEARCH_API_KEY=           # search provider API key (Tavily by default) — without it web_search is not mounted
# LUNA_WEB_SEARCH_PROVIDER=tavily    # search provider (tavily)
# LUNA_WEB_SEARCH_TIMEOUT_MS=15000   # per-search timeout (armed onto the tool's abort signal)
# LUNA_WEB_SEARCH_RESULT_CHARS=800   # per-result snippet clip
# LUNA_WEB_FETCH=1                   # default ON since v0.18.2 (SSRF-guarded, no key needed); 0 = off
# LUNA_WEB_FETCH_TIMEOUT_MS=15000    # per-fetch timeout
# LUNA_WEB_FETCH_MAX_BYTES=3000000   # hard byte cap on a fetched body (streamed, aborts over)
# LUNA_WEB_FETCH_MAX_CHARS=12000     # extracted-markdown char cap (input max_chars overrides)
# LUNA_WEB_CACHE=0                   # default OFF; 1 caches validated fetches in SQLite (a hit never bypasses the SSRF guard)
# LUNA_WEB_CACHE_TTL_MS=900000       # fetch-cache TTL (15 min)
# --- v0.19+ time perception (Initiative 12) ---
# LUNA_TIME_AWARE=1                   # passive time injection (A) — now/gap/daypart in the uncached user tail; default ON since v0.19.2
# LUNA_TZ=Asia/Shanghai              # IANA zone for all time labels; unset = host-resolved zone
# LUNA_TIME_GAP_CONTINUATION_S=600   # gap below this (same calendar day) = "continuation"
# LUNA_TIME_GAP_LONG_AWAY_S=86400    # gap at/above this = "long_away"
# LUNA_RECALL_TIME_LABELS=1          # relative-time labels on recalled memories (B); default ON since v0.19.2
# LUNA_RECALL_ABS_DATE_DAYS=7        # past this many days, labels become an absolute date (on YYYY-MM-DD)
# LUNA_TIME_SUBJECTIVE=1             # felt daypart-mood + absence (C); default ON since v0.19.2
# --- runtime / security ---
# LUNA_BIND_HOST=127.0.0.1           # Bun.serve bind host (default loopback — closes the unauth network surface)
# LUNA_PERSIST=1                     # 0 = fully ephemeral (no SQLite session/L2 persistence)
# LUNA_WORKSPACE_ROOT=               # default cwd for relative paths / shell (NOT a jail — see workspace.ts)
# LUNA_TRACE_RETENTION_TURNS=2000    # how many traced turns to keep before pruning
# --- code-agent capability gates (Initiative 8; all default ON) ---
# LUNA_CODE_WRITE=1                  # 0 unmounts edit/multi_edit/write_file
# LUNA_SHELL=1                       # 0 unmounts the shell tool
# LUNA_SELF_EDIT=1                   # 0 unmounts propose_self_edit (firewalled, human-gated)
# LUNA_SKILLS=1                      # 0 unmounts save_skill/recall_skill
# LUNA_REPO_MAP=1                    # 0 unmounts repo_map/find_symbol
# LUNA_LINT_ON_WRITE=1               # 0 disables the inline lint-on-write syntactic check
# --- memory & recall (Initiative 2 / 10) ---
# LUNA_MEMORY_EMBEDDING=1            # 0 = lexical-only recall (no outbound /v1/embeddings calls)
# LUNA_MEMORY_INJECT=1              # 0 disables auto-injected recall on the hot path
# LUNA_MEMORY_RETRIEVAL_K=12         # default top-k for auto-recall
# LUNA_RECALL_ASYNC=1               # query-embed off the TTFT path (lexical this turn, embed warms the cache)
# LUNA_RECALL_BUDGET_MS=            # embed budget for the hot path; over it the turn scores lexical-only
# LUNA_RECALL_W_RECENCY=1            # GA recall weight: recency
# LUNA_RECALL_W_IMPORTANCE=1         # GA recall weight: importance (salience)
# LUNA_RECALL_W_RELEVANCE=1          # GA recall weight: relevance (cosine/lexical blend)
# --- L1 window / clean history (Initiative 9 / 10) ---
# LUNA_L1_RECENT_TURNS=100           # verbatim window depth in TURNS (range ~40–150)
# LUNA_L1_WINDOW=                    # (legacy v0.4.1 message cap; superseded by LUNA_L1_RECENT_TURNS)
# LUNA_L1_FOLD_BATCH_TURNS=          # how many older turns each fold compresses at once
# LUNA_L1_SUMMARY_MAX_CHARS=         # hard cap on the structured rolling digest
# LUNA_L1_ANCHOR_IMPORTANCE=         # salience score at/above which a folded turn is marked [salient]
# LUNA_KEEP_RECENT_TOOL_MSGS=        # how many recent tool I/O payloads to keep verbatim in durable history
# LUNA_CLEAN_HISTORY=1              # strip thinking + collapse old tool payloads from stored history (~200 tok/turn)
# --- diary & dream tuning (Initiative 10) ---
# LUNA_DIARY_INJECT=1               # standing day/week/month diary digest in the cached system block
# LUNA_DIARY_CANDIDATE_LIMIT=30      # how many recent diaries are recall candidates
# LUNA_DIARY_DIGEST_ENTRY_CHARS=     # per-entry clip in the standing diary digest
# LUNA_DREAM_MAX_DIARIES_PER_CYCLE=  # cap on diaries generated per dream cycle
# LUNA_DREAM_MAX_SALIENCE_PER_CYCLE= # cap on turns rated for salience per dream cycle
# LUNA_ACTIVE_THREAD_TTL_DAYS=       # TTL for L3 active_threads facts
# --- self-continuation (Initiative 5) ---
# LUNA_SELFCONT=1                   # 0 disables the post-turn micro-wake continuation
# LUNA_SELFCONT_PROBABILITY=0.35     # chance of scheduling a continuation after a user turn
# LUNA_SELFCONT_PAUSE_MS=4000        # pause before a continuation fires
# --- local TTS dev (GPT-SoVITS sidecar; outside the roadmap) ---
# LUNA_TTS_DIR=                      # GPT-SoVITS install dir for the local launcher
# LUNA_TTS_PORT=                     # TTS sidecar port
# LUNA_TTS_PROXY=                    # TTS proxy address the web dev-server forwards /api/gpt-sovits/* to
